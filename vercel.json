{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
{
  "rewrites": [
    { "source": "/api/auth",     "destination": "/api/auth.js" },
    { "source": "/api/callback", "destination": "/api/callback.js" },
    { "source": "/api/logout",   "destination": "/api/logout.js" },
    { "source": "/api/proxy",    "destination": "/api/proxy.js" }
  ]
}
